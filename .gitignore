cat << 'EOF' > .gitignore
# ==== Node.js & Frontend ====
node_modules/
.next/
out/
build/
.env*.local

# ==== C++ Backend ====
backend/build/
backend/CMakeCache.txt
backend/CMakeFiles/
*.o
*.out

# ==== IDE & OS ====
.vscode/
.DS_Store

# ==== Third-party & Tests ====
nexttest/node_modules/
EOF


# --- SQLite Database ---
frontend/prisma/*.db
frontend/prisma/*.db-journal

# --- User Uploads ---
#frontend/uploads/
#!frontend/uploads/.gitkeep  # 保留空目录结构，但忽略内容


